{
  "appId": "com.qianqiulp.crewlight.desktop",
  "asar": true,
  "directories": {
    "output": "../../release/desktop-builder"
  },
  "executableName": "Crewlight",
  "extraResources": [
    {
      "from": ".desktop-resources",
      "to": "crewlight-cli",
      "filter": ["**/*"]
    }
  ],
  "files": ["dist/**/*", "package.json"],
  "npmRebuild": false,
  "productName": "Crewlight",
  "win": {
    "artifactName": "Crewlight-${version}.${ext}",
    "icon": "./assets/crewlight-icon.ico"
  },
  "nsis": {
    "artifactName": "Crewlight-Setup-v${version}.${ext}",
    "oneClick": true,
    "perMachine": false,
    "allowToChangeInstallationDirectory": false
  },
  "mac": {
    "artifactName": "Crewlight-${version}-${arch}.${ext}",
    "icon": "./assets/crewlight-icon.png",
    "category": "public.app-category.developer-tools",
    "target": [
      {
        "target": "dmg",
        "arch": ["arm64", "x64"]
      }
    ]
  },
  "dmg": {
    "artifactName": "Crewlight-${version}-${arch}.${ext}"
  },
  "linux": {
    "artifactName": "Crewlight-${version}-${arch}.${ext}",
    "icon": "./assets/crewlight-icon.png",
    "category": "Development",
    "target": [
      {
        "target": "AppImage",
        "arch": ["x64", "arm64"]
      },
      {
        "target": "deb",
        "arch": ["x64"]
      }
    ]
  }
}
