{
  "name": "crewlight",
  "version": "0.4.0",
  "description": "Crewlight is a local-first companion surface for multi-agent coding workflows.",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -b && pnpm --filter @crewlight/companion copy:assets",
    "build:standalone": "pnpm build && node scripts/build-standalone.mjs",
    "clean": "tsc -b --clean",
    "companion:dev": "pnpm --filter @crewlight/companion dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "smoke:standalone": "bash scripts/smoke-standalone.sh",
    "smoke:standalone:windows": "pwsh -NoLogo -NoProfile -ExecutionPolicy Bypass -File scripts/smoke-standalone.ps1",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -b --pretty false"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "esbuild": "^0.27.7",
    "postject": "1.0.0-alpha.6",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  }
}
